#!/usr/bin/env bash
#
# Pre-commit hook: scan the staged diff for API keys and other secrets.
# Enable once per clone with:
#   git config core.hooksPath .githooks
#
# The pattern set lives in scripts/check-no-secrets.sh so the hook and CI
# share exactly one source of truth.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
exec "$repo_root/scripts/check-no-secrets.sh" --staged
