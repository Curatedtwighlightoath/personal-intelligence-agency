# Copy to .env and fill in values. .env is gitignored.
# The `department_config` table stores the NAME of the env var to read
# (e.g. "ANTHROPIC_API_KEY"), never the secret itself.

# --- LLM providers ---
# At least one of these must be set for whichever provider a department uses.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# For local models via Ollama's OpenAI-compatible endpoint, configure the
# department with provider=openai, base_url=http://localhost:11434/v1, and
# point api_key_ref at an env var with any non-empty placeholder value
# (Ollama ignores it but the SDK requires something).
OLLAMA_API_KEY=ollama

# --- External data sources ---
# Optional; raises GitHub API rate limit from 60/hr to 5000/hr.
GITHUB_TOKEN=

# --- Database ---
# Postgres + pgvector. Install Postgres natively (see README), then:
#   createdb pia
#   psql -d pia -c "CREATE EXTENSION IF NOT EXISTS vector;"
# Apply migrations with `python -m migrations.runner` from PIA-RECON/.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pia

# --- Embeddings (R&D + memory_items) ---
# Provider + model used to embed text for the memory_items table. Dimension
# of the `embedding vector(N)` column is fixed at migration time; swapping
# to a different-dimension model requires a re-embed migration.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
